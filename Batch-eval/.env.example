# scripts/deploy.ps1 (または deploy.sh) が eval/.env を自動生成します。
# 手動設定する場合はこのファイルを eval/.env にコピーして値を埋めてください。

AZURE_TENANT_ID=<AZURE_TENANT_ID>
AZURE_SUBSCRIPTION_ID=<AZURE_SUBSCRIPTION_ID>
AZURE_RESOURCE_GROUP=rg-agenteval-batcheval

# Foundry プロジェクト エンドポイント
PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>

# ジャッジ（AI支援評価器）用 GPT デプロイ名
MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
JUDGE_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Application Insights
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
APPLICATIONINSIGHTS_NAME=appi-agenteval-xxxxx

# トレース評価用（agent/create_agent.py 実行後に設定）
AGENT_ID=contoso-support-agent:2
TRACE_LOOKBACK_HOURS=1
TRACE_MAX_TRACES=20

# Contoso ポリシー MCP サーバー（scripts/deploy-mcp.ps1 が自動生成）
# Foundry エージェントの mcp ツールとして接続する公開 HTTPS エンドポイントと API キー。
CONTOSO_MCP_URL=https://contoso-policy-mcp.<region>.azurecontainerapps.io/mcp
CONTOSO_MCP_KEY=<32桁のランダム API キー>


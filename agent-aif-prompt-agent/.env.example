# 自動生成のひな型。scripts/deploy.ps1 (deploy.sh) が実値を書き込みます。
# 手動設定する場合は ms-foundry-observability の出力値を転記してください。

# 認証コンテキスト
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# Foundry プロジェクト（ms-foundry-observability の出力）
PROJECT_ENDPOINT=
MODEL_DEPLOYMENT_NAME=gpt-5.4
# エージェント専用にモデルを上書きする場合のみ設定（未設定なら MODEL_DEPLOYMENT_NAME を使用）
AGENT_MODEL_DEPLOYMENT_NAME=

# トレース送信先（ms-foundry-observability の App Insights）
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPLICATIONINSIGHTS_NAME=

# Contoso ポリシー MCP（任意。未設定なら MCP ツールなしで作成）
CONTOSO_MCP_URL=
CONTOSO_MCP_KEY=
